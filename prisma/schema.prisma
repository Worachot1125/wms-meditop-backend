model swap {
  id         Int     @id @default(autoincrement())
  name       String?
  no         String? @unique
  picking_id Int?

  odoo_location_id   Int?
  source_location_id Int?
  source_location    String?

  // ปลายทางจาก Odoo
  odoo_location_dest_id Int?
  dest_location_id      Int?
  dest_location         String?

  location_id   Int?
  location      location? @relation("SwapLocation", fields: [location_id], references: [id])
  location_name String

  // relation ปลายทางในระบบเรา
  location_dest_id   Int?
  location_dest      location? @relation("SwapLocationDest", fields: [location_dest_id], references: [id])
  location_dest_name String?

  department_id Int?
  department    department? @relation(fields: [department_id], references: [id])

  status    String?
  user_ref  String?
  remark    String?
  origin    String?
  reference String?

  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  swapItems swap_item[]

  @@index([picking_id])
  @@index([location_id])
  @@index([location_dest_id])
  @@index([department_id])
  @@index([status])
  @@index([name])
  @@map("swaps")
}

model swap_item {
  id      Int  @id @default(autoincrement())
  swap_id Int
  swap    swap @relation(fields: [swap_id], references: [id])

  source_sequence Int?
  odoo_line_key   String?
  product_id      Int?
  code            String?
  name            String?
  unit            String?
  tracking        String?

  lot_id          Int?
  lot_serial      String?
  barcode_text    String?
  expiration_date DateTime?

  system_qty   Int @default(0)
  executed_qty Int @default(0)

  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  @@index([swap_id])
  @@index([product_id])
  @@index([lot_serial])
  @@index([odoo_line_key])
  @@map("swap_items")
}
