model transfer_doc_item {
  id               String    @id @default(uuid())
  name             String
  quantity_receive Int?
  quantity_count   Int?
  quantity_put     Int       @default(0)
  unit             String
  zone_type        String?
  lot              String?
  exp              DateTime?
  barcode13        String?
  qr_payload       String?
  created_at       DateTime  @default(now())
  updated_at       DateTime?
  deleted_at       DateTime?
  code             String?
  lot_id           Int?
  lot_serial       String?
  product_id       Int?
  qty              Int?
  sequence         Int?
  tracking         String?
  transfer_doc_id  Int?
  barcode_id       Int?
