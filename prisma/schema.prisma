model transfer_movement {
  id     Int    @id @default(autoincrement())
  no     String @unique
  status String @default("pick")

  user_id Int
  user    user @relation(fields: [user_id], references: [id])

  // ✅ ของเดิม (compat)
  user_work_id Int?

  // ✅ ของเดิม (compat)
  department_id Int
  department    department @relation(fields: [department_id], references: [id])

  // ✅ NEW relations (หลาย department / หลาย user_work)
  movement_departments transfer_movement_department[]
  movement_user_works  transfer_movement_user_work[]

  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  items transfer_movement_item[]

  @@index([user_id])
  @@index([department_id])
  @@map("transfer_movements")
}

model transfer_movement_item {
  id           String    @id @default(uuid()) // เหมือน goods_in
  sequence     Int?
  product_id   Int?
  code         String?
  name         String
  lock_no      String?
  lock_no_dest String?
  lot_serial   String?
  unit         String
  exp          DateTime?
  qty          Int?
  qty_pick     Int       @default(0)
  qty_put      Int       @default(0)
  status       String?   @default("pick") // pick, put, completed

  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  transfer_movement_id                     Int?
  transfer_movement                        transfer_movement?                             @relation(fields: [transfer_movement_id], references: [id])
  transferMovementItemLocationPutConfirms  transfer_movement_item_location_put_confirm[]
  transferMovementItemLocationPickConfirms transfer_movement_item_location_pick_confirm[]

  @@index([transfer_movement_id, product_id])
  @@map("transfer_movement_items")
}

model transfer_movement_department {
  id Int @id @default(autoincrement())

  transfer_movement_id Int
  department_id        Int

  transfer_movement transfer_movement @relation(fields: [transfer_movement_id], references: [id])
  department        department        @relation(fields: [department_id], references: [id])

  created_at DateTime @default(now())

  @@unique([transfer_movement_id, department_id])
  @@index([department_id])
  @@index([transfer_movement_id])
  @@map("transfer_movement_departments")
}

model transfer_movement_user_work {
  id Int @id @default(autoincrement())

  transfer_movement_id Int
