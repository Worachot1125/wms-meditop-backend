  transfer_doc_item_location_confirms transfer_doc_item_location_confirm[] @relation("TFToLocConfirm")

  ncr_locations                           transfer_doc_item_ncr_location[]         @relation("TFItemToNcrLoc")
  transfer_doc_item_location_put_confirms transfer_doc_item_location_put_confirm[] @relation("TFToLocPutConfirm")

